# Tastytrade OAuth (from developer portal)
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=

# Redirect URI (must match what's registered in Tastytrade OAuth app)
TASTYTRADE_REDIRECT_URI=http://localhost:8000/auth/tastytrade/callback

# Supabase (service role key — server-side only, never expose to client)
SUPABASE_URL=https://dacmqkjvofqqjfsfrtlp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Streamlit app URL (redirect destination after OAuth)
STREAMLIT_APP_URL=http://localhost:8501
