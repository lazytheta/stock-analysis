{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs python3 -m ruff check --no-fix 2>&1 | head -20"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/administrator/Documents/github/stock-analysis/.claude/lint-and-test.sh"
          }
        ]
      }
    ]
  }
}
